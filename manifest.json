{
  "manifest_version": 3,
  "name": "Evolver",
  "version": "3.1",
  "description": "Auto-fills exam answers using AI.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.mistral.ai/*",
    "https://api.x.ai/*",
    "http://localhost:1234/*",
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*"
  ],
  "icons": {
    "16": "image_0baa28.png",
    "32": "image_0baa28.png",
    "48": "image_0baa28.png",
    "128": "image_0baa28.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "image_0baa28.png",
      "32": "image_0baa28.png",
      "48": "image_0baa28.png",
      "128": "image_0baa28.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}